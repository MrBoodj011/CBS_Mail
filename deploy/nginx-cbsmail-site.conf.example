server {
    listen 443 ssl http2;
    server_name cbsmail.example.com;

    root /var/www/cbsmail;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/cbsmail.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cbsmail.example.com/privkey.pem;

    add_header Strict-Transport-Security "max-age=31536000" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;
    add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self'; object-src 'none'; script-src 'self'; style-src 'self'; upgrade-insecure-requests" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(?:ico|jpg|jpeg|png|svg|webp)$ {
        expires 30d;
        try_files $uri =404;
    }

    location ~* \.(?:css|js)$ {
        expires 7d;
        try_files $uri =404;
    }
}

server {
    listen 80;
    server_name cbsmail.example.com;
    return 301 https://$host$request_uri;
}
